# =============================================================================
# UBIRT — Environment variables reference
# Copy to `.env.local` for local dev. Set the same keys on Vercel for production.
# Never commit `.env.local` (it is gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# APP MODE
# -----------------------------------------------------------------------------
# mock = demo data, no login | live = Supabase backend
VITE_DATA_PROVIDER=mock

# Public site URL (auth redirects, email links). e.g. http://localhost:5173 or https://your-app.vercel.app
VITE_APP_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# SUPABASE (required for live mode) — https://supabase.com
# Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Server-only. Dashboard → API → service_role (never expose to browser / VITE_)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_URL=https://your-project.supabase.co

# Optional: use Resend as Supabase Auth SMTP (Authentication → SMTP Settings)
# Host: smtp.resend.com | User: resend | Password: your RESEND_API_KEY

# -----------------------------------------------------------------------------
# OPENAI (AI chat) — https://platform.openai.com/api-keys
# Server-only. Used by api/ai/chat.js on Vercel / `npx vercel dev`
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# RESEND (transactional email) — https://resend.com/api-keys
# Welcome, password reset (custom routes), notifications
# Server-only. Verify domain or use onboarding@resend.dev for testing
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=UBIRT

# -----------------------------------------------------------------------------
# MUX (video streaming, optional) — https://dashboard.mux.com/settings/access-tokens
# Server-only. Used by api/video/ingest.js
# -----------------------------------------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# STRIPE (payments, optional) — https://dashboard.stripe.com/apikeys
# For creator subscriptions / tips (not wired yet)
# -----------------------------------------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# SENTRY (error monitoring, optional) — https://sentry.io
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# POSTHOG (product analytics, optional) — https://posthog.com
# -----------------------------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# PUSH DELIVERY (server-only)
# -----------------------------------------------------------------------------
# Firebase project (e.g. ubirtai). The web SDK snippet from Firebase Console is
# client-side only — server push needs the service account below.
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=ubirtai
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ubirtai.iam.gserviceaccount.com
# Paste private_key from JSON; in Vercel use literal \n for newlines inside quotes
FIREBASE_PRIVATE_KEY=
#
# APNs token auth
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.elhubventures.ubirt
# Multi-line .p8 contents (escaped with \n in Vercel env var)
APNS_PRIVATE_KEY=
# Use "true" for development sandbox, "false" for production
APNS_USE_SANDBOX=true
#
# DEPLOYMENT NOTES (no env vars in repo)
# -----------------------------------------------------------------------------
#
# Native OAuth redirect:
# - Web: keep VITE_APP_URL as your website URL (https://app.ubirtai.site)
# - iOS/Android OAuth callback registered in Supabase: com.elhubventures.ubirt://login
#
# GitHub  — source control
# Vercel  — hosting + serverless API (import repo, paste env vars from this file)
# Domain  — optional custom domain on Vercel
